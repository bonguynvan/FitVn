# =============================================================================
# FitVN environment variables
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# Project URL (Project Settings -> API -> Project URL). Safe to expose to client.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public API key (Project Settings -> API -> anon public). Safe to expose.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key (Project Settings -> API -> service_role). SERVER ONLY.
# Bypasses Row Level Security. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Anthropic / Claude ------------------------------------------------------
# API key for the Claude API used by the AI coach. SERVER ONLY.
# Get it from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# --- Web Push (VAPID) --------------------------------------------------------
# Generate a key pair with: npx web-push generate-vapid-keys
# Public key is sent to the browser to subscribe a device. Safe to expose.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# Private key used by the server to sign push payloads. SERVER ONLY.
VAPID_PRIVATE_KEY=your-vapid-private-key

# Contact subject for push services. Must be a mailto: or https: URL.
VAPID_SUBJECT=mailto:you@example.com
